# Environment variables
.env

# Temporary measurement snapshots (probe_mcp_surface.py)
tmp_*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
# office_mcp/build/ holds the scene-authoring *source* (build_scene.py), not
# build output — keep it tracked despite the generic build/ rule above.
!office_mcp/build/
!office_mcp/build/**

# Virtual environment
.venv/

# Testing / Linting caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
.vs/
*.swp
*.swo

# Node.js
node_modules/

# OS
.DS_Store
Thumbs.db

# OMC (local tool state)
.omc/

# Application state
state/

# Claude Code runtime state (scheduled_tasks.lock etc. — not project code)
.claude/*
# Exception: project-local skills should be shared across sessions/teammates
!.claude/skills/

# Local log files (kit.exe stdout redirect lands in %TEMP%, but catch any that slip into repo)
*.log

# Binary capture artifacts (viewport PNGs, recordings, numpy dumps).
# Default capture target is %TEMP%/validation_api_captures/ — these patterns guard
# against accidental check-in if someone redirects output into the repo.
# Commit selectively via `git add -f` when a capture is needed as doc reference.
*.mp4
*.mov
*.webm
docs/artifacts/**/*.png
docs/artifacts/**/*.jpg
docs/artifacts/**/*.jpeg
docs/artifacts/**/*.npy
docs/artifacts/**/*.pkl
# Live test JSON reports (regenerated per run; summaries are captured in phase-*-validation-report.md)
docs/artifacts/**/*.json

# Phase H replicator scenario output (default output_dir for replicator_create_writer)
_temp_sdg/
sdg_mcp/scenes/dataset/
sdg_mcp/scenes/dataset_prev/

# Workspace-local task prompts
workspaces/*/instance-*/*-task-prompt.md

# Worktree dir (future use; keep ignored even if we don't create one now)
.worktrees/

# Standalone script artifacts (kit log copies / verify results)
docs/artifacts/multi-instance-smoke/
docs/artifacts/multi-app-smoke/

# Codex CLI runtime data (workspace-local; config.toml only)
# codex CLI 가 `.codex/` 안에 sessions/, logs_*.sqlite, installation_id, state_*.sqlite, skills/, tmp/ 등 runtime 자동 생성
# config.toml 만 commit, 나머지는 ignore (sensitive session content / 로그 보호)
workspaces/*/instance-*/.codex/*
!workspaces/*/instance-*/.codex/config.toml

