# ===== 멀티 인스턴스 × 멀티 앱 (선택) =====
# Claude Code 세션마다 독립된 kit.exe 를 쓰고 싶을 때.
#
# ISAAC_MCP_APP_PROFILE 선택지:
#   isaac-sim     → Isaac Sim 6.0 standalone (port 8111 + (instance-1))
#   usd-composer  → kit-app-template USD Composer (port 8114 + (instance-1))
#
# 기본값: isaac-sim + instance 1 → port 8111
#
# ISAAC_MCP_APP_PROFILE=isaac-sim
# ISAAC_MCP_INSTANCE_ID=1

# ===== Isaac Sim 6.0.0 Standalone 설치 경로 (필수) =====
# 설치 위치는 자동 탐지되지 않습니다. 아래 두 경로를 본인 환경에 맞춰 override.
# 기본값은 config.py 에 하드코딩되어 있으며 이 두 env var 로 오버라이드합니다.
# Public repo 에 개인 절대경로를 커밋하지 마세요.
# ISAAC_SIM_KIT_EXE=C:/path/to/isaac-sim-standalone-6.0.0-windows-x86_64/kit/kit.exe
# ISAAC_SIM_KIT_FILE=C:/path/to/isaac-sim-standalone-6.0.0-windows-x86_64/apps/isaacsim.exp.full.kit

# ===== USD Composer / Kit App Template 빌드 경로 (usd-composer profile 사용 시) =====
# USD Composer profile은 Isaac Sim 경로 override를 사용하지 않습니다.
# kit-app-template release 빌드 위치에 맞춰 아래 두 경로를 설정하세요.
# USD_COMPOSER_KIT_EXE=C:/path/to/kit-app-template/_build/windows-x86_64/release/kit/kit.exe
# USD_COMPOSER_KIT_FILE=C:/path/to/kit-app-template/_build/windows-x86_64/release/apps/kkr_usd_composer.kit

# Isaac Sim REST API
# 명시 override 가 필요할 때만 해제. 미설정 시 app_profile + instance_id 로 자동 파생.
# ISAAC_SIM_BASE_URL=http://127.0.0.1:8111
ISAAC_SIM_TIMEOUT=30.0
# kit.exe 첫 기동 상한 (shader 컴파일 + extra ext 로드). cold boot 여유.
# ISAAC_SIM_STARTUP_TIMEOUT=600.0

# Isaac Sim Extension 활성화 (JSON array only, pydantic-settings v2 limitation)
# 루트 CLAUDE.md 의 "Environment Variables" 섹션 참조
ISAAC_SIM_EXTRA_EXT_IDS=["omni.anim.graph.bundle","omni.anim.navigation.bundle","isaacsim.replicator.agent.core","omni.kit.ui_test","isaacsim.sensors.experimental.rtx","isaacsim.sensors.experimental.physics","isaacsim.ros2.bridge","omni.graph.action","omni.replicator.core","omni.mycompany.navmesh_playground"]

# Lakehouse REST API
LAKEHOUSE_BASE_URL=http://localhost:9000
LAKEHOUSE_TIMEOUT=30.0

# MCP Server
MCP_SERVER_NAME=isaacsim-validation-mcp
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# Scenarios
SCENARIOS_DIR=scenarios
SCENARIO_DEFAULT_TIMEOUT=600.0
